            travel: {
                title: '旅行外出運勢',
                content: '外出運勢平順，旅途愉快。注意行程規劃，確保安全。適合短途旅行，放鬆心情。',
                luckyColor: '天藍色',
                luckyNumber: 6
            },
            decision: {
                title: '重要決策運勢',
                content: '決策運勢清晰，思路明確。適合做出重要決定，但需謹慎評估。聽取多方意見，做出最佳選擇。',
                luckyColor: '深藍色',
                luckyNumber: 7
            },
            opportunity: {
                title: '機會運勢',
                content: '機會運勢旺盛，有新的發展機會。需積極把握，展現能力。適合嘗試新事物，拓展領域。',
                luckyColor: '金色',
                luckyNumber: 9
            },
            relationship: {
                title: '人際關係運勢',
                content: '人際關係順暢，貴人相助。與朋友同事相處融洽，合作順利。適合社交活動，拓展人脈。',
                luckyColor: '粉色',
                luckyNumber: 5
            },
            creativity: {
                title: '創意靈感運勢',
                content: '創意靈感豐富，想像力活躍。適合藝術創作、寫作或設計工作。發揮創意，將有出色表現。',
                luckyColor: '彩虹色',
                luckyNumber: 3
            }
        };
        
        // 運勢查詢功能 - 在結果中間插入廣告
        function getFortune() {
            const birthDate = document.getElementById('birth-date').value;
            const questionType = document.getElementById('question-type').value;
            
            if (!birthDate) {
                alert('請輸入出生年月日');
                return;
            }
            
            const fortune = expandedFortunes[questionType] || expandedFortunes.general;
            
            // 隨機選擇一個結果中間廣告
            const resultAd = resultAds[Math.floor(Math.random() * resultAds.length)];
            
            // 建立運勢結果HTML，在中間插入廣告
            const fortuneHTML = `
                <p><strong>${fortune.title}</strong></p>
                <p>${fortune.content}</p>
                
                <!-- 結果中間廣告 -->
                <div class="result-ad">
                    <img src="${resultAd.image}" alt="${resultAd.title}" class="result-ad-image">
                    <h4>${resultAd.title}</h4>
                    <p>${resultAd.description}</p>
                    <a href="#" class="result-ad-button" onclick="trackAd('${resultAd.id}')">${resultAd.buttonText}</a>
                </div>
                
                <div style="margin-top: 15px;">
                    <span style="color: #ffd166;">幸運色：${fortune.luckyColor}</span> | 
                    <span style="color: #ffd166;">幸運數字：${fortune.luckyNumber}</span>
                </div>
                <p style="margin-top: 15px; font-style: italic; color: #aaa;">
                    以上分析僅供參考，實際運勢取決於個人努力與選擇。
                </p>
            `;
            
            document.getElementById('fortune-content').innerHTML = fortuneHTML;
            document.getElementById('fortune-result').style.display = 'block';
            
            // 顯示小方塊廣告（運算完成後）
            setTimeout(() => {
                showMiniAd();
            }, 1000);
            
            // 滾動到結果
            document.getElementById('fortune-result').scrollIntoView({ behavior: 'smooth' });
        }
        
        // 靈籤堂功能
        function showFortuneStick() {
            document.getElementById('overlay').classList.add('active');
            document.getElementById('fortuneStickPopup').classList.add('active');
            document.getElementById('fortuneStickResult').style.display = 'none';
        }
        
        function closeFortuneStick() {
            document.getElementById('overlay').classList.remove('active');
            document.getElementById('fortuneStickPopup').classList.remove('active');
        }
        
        function drawFortuneStick(category) {
            const sticks = fortuneSticks[category] || fortuneSticks.general;
            const stick = sticks[Math.floor(Math.random() * sticks.length)];
            
            document.getElementById('stickTitle').textContent = stick.title;
            document.getElementById('stickContent').innerHTML = `
                <p>${stick.content}</p>
                <div style="margin-top: 15px;">
                    <span style="color: #9d4edd;">幸運色：${stick.luckyColor}</span> | 
                    <span style="color: #9d4edd;">幸運數字：${stick.luckyNumber}</span>
                </div>
                <p style="margin-top: 15px; font-style: italic; color: #aaa;">
                    籤詩僅供參考，實際運勢取決於個人努力與選擇。
                </p>
            `;
            
            document.getElementById('fortuneStickResult').style.display = 'block';
            
            // 顯示廣告
            setTimeout(() => {
                showServiceAd('靈籤堂', '抽籤相關商品推薦');
            }, 1500);
        }
        
        function drawFortuneStickAgain() {
            const buttons = document.querySelectorAll('.fortune-stick-btn');
            const activeButton = Array.from(buttons).find(btn => 
                btn.textContent.includes(document.getElementById('stickTitle').textContent.split(' - ')[1] || '')
            );
            
            if (activeButton) {
                const category = activeButton.getAttribute('onclick').match(/drawFortuneStick\('(.+?)'\)/)[1];
                drawFortuneStick(category);
            } else {
                drawFortuneStick('general');
            }
        }
        
        // 顯示服務相關跳出廣告
        function showServiceAd(serviceName, adDescription) {
            const relatedAds = ads.filter(ad => 
                ad.service.includes(serviceName) || 
                serviceName.includes(ad.service)
            );
            
            const ad = relatedAds.length > 0 ? relatedAds[0] : ads[0];
            
            document.getElementById('popupAdTitle').textContent = ad.title;
            document.getElementById('popupAdDesc').textContent = ad.description;
            document.getElementById('popupAdCategory').textContent = ad.category;
            document.getElementById('popupAdPrice').textContent = ad.price;
            
            // 更新跳出廣告圖片
            const popupImage = document.querySelector('.popup-image');
            if (popupImage) {
                popupImage.src = ad.image;
                popupImage.alt = ad.title;
            }
            
            // 儲存當前廣告ID
            window.currentAdId = ad.id;
            
            // 顯示跳出廣告
            document.getElementById('overlay').classList.add('active');
            document.getElementById('popupAd').classList.add('active');
        }
        
        // 關閉跳出廣告
        function closePopupAd() {
            document.getElementById('overlay').classList.remove('active');
            document.getElementById('popupAd').classList.remove('active');
        }
        
        // 訪問廣告
        function visitAd() {
            if (window.currentAdId) {
                trackAd(window.currentAdId);
            }
            closePopupAd();
        }
        
        // 顯示小方塊廣告
        function showMiniAd() {
            const miniAd = document.getElementById('miniAd');
            
            // 隨機選擇一個廣告
            const randomAd = ads[Math.floor(Math.random() * ads.length)];
            
            // 更新小方塊廣告內容
            const miniImage = miniAd.querySelector('.mini-image');
            if (miniImage) {
                miniImage.src = randomAd.image;
                miniImage.alt = randomAd.title;
            }
            
            const miniTitle = miniAd.querySelector('h4');
            if (miniTitle) {
                miniTitle.textContent = randomAd.title;
            }
            
            const miniDesc = miniAd.querySelector('p');
            if (miniDesc) {
                miniDesc.textContent = randomAd.description;
            }
            
            // 儲存當前廣告ID
            window.currentMiniAdId = randomAd.id;
            
            // 顯示小方塊廣告
            miniAd.classList.add('show');
            
            // 10秒後自動隱藏
            setTimeout(() => {
                miniAd.classList.remove('show');
            }, 10000);
        }
        
        // 關閉小方塊廣告
        function closeMiniAd() {
            document.getElementById('miniAd').classList.remove('show');
        }
        
        // 追蹤小方塊廣告點擊
        function trackMiniAd() {
            if (window.currentMiniAdId) {
                trackAd(window.currentMiniAdId);
            }
            closeMiniAd();
        }
        
        // 廣告點擊追蹤（後台記錄，不顯示給用戶）
        function trackAd(adId) {
            // 後台追蹤記錄
            const trackData = {
                adId: adId,
                memberId: '3QWtn', // 後台使用，不顯示
                timestamp: new Date().toISOString(),
                pageUrl: window.location.href,
                userAgent: navigator.userAgent
            };
            
            console.log('廣告追蹤（後台）:', trackData);
            
            // 模擬跳轉
            alert('即將導向商品頁面...');
            
            // 實際會發送到iChannels追蹤系統
            // fetch('/api/track-ad', { method: 'POST', body: JSON.stringify(trackData) });
            
            return true;
        }
        
        // 頁面載入完成
        document.addEventListener('DOMContentLoaded', function() {
            console.log('天機閣網站載入完成 - 靈籤堂與擴充運勢版');
            
            // 設定今天為預設日期
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('birth-date').value = today;
            
            // 點擊遮罩層關閉廣告
            document.getElementById('overlay').addEventListener('click', function() {
                closePopupAd();
                closeFortuneStick();
            });
            
            // 5秒後顯示小方塊廣告（首次進入）
            setTimeout(() => {
                showMiniAd();
            }, 5000);
            
            // 修復廣告pop up問題
            if (typeof showServiceAd === 'undefined') {
                console.error('showServiceAd函數未定義！');
                // 重新定義函數
                window.showServiceAd = function(serviceName, adDescription) {
                    console.log('showServiceAd被呼叫:', serviceName);
                    alert('服務廣告: ' + serviceName + '\n' + adDescription);
                };
            }
            
            // 添加測試按鈕
            const servicesSection = document.querySelector('.services');
            if (servicesSection) {
                const testButton = document.createElement('button');
                testButton.textContent = '🔧 測試所有功能';
                testButton.style.cssText = `
                    display: block;
                    margin: 20px auto;
                    padding: 10px 20px;
                    background: #ff6b6b;
                    color: white;
                    border: none;
                    border-radius: 5px;
                    cursor: pointer;
                    font-size: 14px;
                `;
                testButton.onclick = function() {
                    // 測試運勢查詢
                    getFortune();
                    // 測試靈籤堂
                    setTimeout(() => {
                        showFortuneStick();
                    }, 2000);
                    // 測試跳出廣告
                    setTimeout(() => {
                        showServiceAd('測試服務', '測試廣告描述');
                    }, 4000);
                };
                servicesSection.appendChild(testButton);
            }
        });
    </script>
    <!-- 廣告系統（獨立載入，不影響主系統） -->
    <script src="../ads/ads.js"></script>
</body>
</html>

<script>
// 動態載入廣告標題和描述
document.addEventListener('DOMContentLoaded', function() {
    // 載入 ads.js
    const script = document.createElement('script');
    script.src = '../ads/ads.js';
    script.onload = function() {
        // 更新天機閣廣告
        updateDestinyAds();
    };
    document.head.appendChild(script);
});

function updateDestinyAds() {
    if (!window.destinyAds) return;
    
    // 更新廣告區塊標題
    const titleEl = document.getElementById('destiny-ad-section-title');
    const descEl = document.getElementById('destiny-ad-section-desc');
    
    if (titleEl) titleEl.textContent = '精選推薦商品';
    if (descEl) descEl.textContent = '以下為精選商品，點擊圖片了解更多：';
    
    // 更新各個廣告卡片
    const adTitles = document.querySelectorAll('.ad-title');
    const adDescs = document.querySelectorAll('.ad-description');
    
    // 使用 destinyAds 中的資料
    for (let i = 0; i < Math.min(adTitles.length, destinyAds.length); i++) {
        adTitles[i].textContent = destinyAds[i].title;
        adDescs[i].textContent = destinyAds[i].description;
    }
}
</script>
